# =============================================================================
# SkillsAI Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
# Base API URL — dm, axd, lms, and studio are derived as {base}/dm, {base}/axd, etc.
NEXT_PUBLIC_API_BASE_URL=https://api.iblai.app
NEXT_PUBLIC_LMS_URL=https://learn.iblai.app
NEXT_PUBLIC_DM_URL_TEST=
NEXT_PUBLIC_AUTH_URL=https://login.iblai.app
NEXT_PUBLIC_MFE_URL=https://apps.learn.iblai.app
NEXT_PUBLIC_SPA_ANALYTICS_URL=https://analytics.iblai.app
NEXT_PUBLIC_MENTOR_URL=https://mentorai.iblai.app

# -----------------------------------------------------------------------------
# Platform Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLATFORM_BASE_DOMAIN=
NEXT_PUBLIC_SUPPORT_EMAIL=support@ibl.ai
NEXT_PUBLIC_COPYRIGHT=

# -----------------------------------------------------------------------------
# Feature Flags (true / false)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HIDE_RECOMMENDED_TAB=false
NEXT_PUBLIC_COURSE_ELIGIBILITY_ENABLED=false
NEXT_PUBLIC_ENABLE_COURSE_ELIGIBILITY_LICENSE_CHECK=false
NEXT_PUBLIC_ENABLE_START_ROLE=false
NEXT_PUBLIC_ENABLE_MENTOR=true
NEXT_PUBLIC_ENABLE_GRAVATAR_ON_PROFILE_PIC=true
NEXT_PUBLIC_ENABLE_RBAC=false
NEXT_PUBLIC_USE_FOOTER_MENUS=false
NEXT_PUBLIC_ENABLE_COMBINED_RECOMMENDATION_REPORT=false

# -----------------------------------------------------------------------------
# UI Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of discover facet filters to hide
NEXT_PUBLIC_DISCOVER_FACETS_FILTERS_TO_HIDE=

# JSON array of footer menu items (used when NEXT_PUBLIC_USE_FOOTER_MENUS=true)
NEXT_PUBLIC_FOOTER_MENUS=

# Default embedded mentor name
NEXT_PUBLIC_DEFAULT_EMBEDDED_MENTOR_NAME=mentorAI

# Combined recommendation reports config
NEXT_PUBLIC_COMBINED_RECOMMENDATION_REPORTS=
