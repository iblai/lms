#!/bin/sh

echo "Building..."
pnpm build

echo "Running lint..."
pnpm lint

echo "Running typecheck..."
pnpm typecheck

echo "Running unit tests..."
pnpm test

echo "Checking test coverage for changed files..."
bash ./scripts/check-test-coverage.sh

echo "Checking E2E journey coverage for changed files..."
node e2e/scripts/check-journey-coverage.mjs --no-regress

if command -v claude >/dev/null 2>&1; then
	echo "Claude is reviewing your code..."
	claude --print "/code-review"
else

	echo "OpenCode is reviewing your code..."
	opencode run --command "code-review"
fi
